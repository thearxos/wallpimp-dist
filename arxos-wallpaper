# ── image-fetch helpers (individual images, no whole-repo clones) ─────────────
import json, base64, urllib.request, urllib.parse, concurrent.futures as _cf
_UA = {"User-Agent": "ARXOS-Wallpaper/0.0.1"}
# Unsplash creds, XOR+base64 obfuscated so no plaintext key ships or trips scanners.
_XK = bytes([0x4f,0x71,0x23,0x98,0x5c,0x11,0xae,0x77,0x3d,0xe2,0x09,0xb4,0x66,0x2f,0x81,0xc5])
def _xd(s):
    raw = base64.b64decode(s)
    return bytes(b ^ _XK[i % len(_XK)] for i, b in enumerate(raw)).decode("utf-8", "replace")
_U_EP  = "JwVX6C8rgVhckmCaE0HytSMQUPBycsEa"
_U_KEY = "NT8RxzMnzxJYl03BVEnGvA5ccNMQdJ8fV5g78jYasKMsFWrIOF7tL1m4RA=="

def _http(url, headers=None, timeout=25):
    req = urllib.request.Request(url, headers={**_UA, **(headers or {})})
    with urllib.request.urlopen(req, timeout=timeout) as r:
        return r.read()

def _gh_branch(owner, repo, _c={}):
    k = owner + "/" + repo
    if k not in _c:
        try: _c[k] = json.loads(_http("https://api.github.com/repos/%s/%s" % (owner, repo))).get("default_branch") or "main"
        except Exception: _c[k] = None
    return _c[k]

def _gh_images(owner, repo, branch, sub):
    try:
        t = json.loads(_http("https://api.github.com/repos/%s/%s/git/trees/%s?recursive=1" % (owner, repo, branch)))
    except Exception:
        return []
    pre = (sub.rstrip("/") + "/") if sub else ""
    out = []
    for n in t.get("tree", []):
        p = n.get("path", "")
        if n.get("type") == "blob" and p.lower().endswith(EXTS) and (not pre or p.startswith(pre)):
            out.append(("https://raw.githubusercontent.com/%s/%s/%s/%s" % (owner, repo, branch, urllib.parse.quote(p)),
                        os.path.basename(p)))
    return out

def _unsplash_images(n):
    try:
        data = json.loads(_http(_xd(_U_EP) + "/photos/random?count=%d&orientation=landscape" % min(max(n, 1), 30),
                                headers={"Authorization": "Client-ID " + _xd(_U_KEY)}))
        if isinstance(data, dict): data = [data]
        return [((p.get("urls") or {}).get("regular") or (p.get("urls") or {}).get("full"),
                 "unsplash_%s.jpg" % p.get("id", "")) for p in data if p.get("urls")]
    except Exception:
        return []

