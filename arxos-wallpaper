            p = random.choice(self.papers); set_wallpaper(p)

    def download(self, *_):
        d = Gtk.Dialog(title="Download wallpapers", transient_for=self, modal=False); d.set_default_size(580, 470)
        d.add_button("Close", Gtk.ResponseType.CLOSE)
        a = d.get_content_area(); a.set_spacing(8)
        for m in ("set_margin_top","set_margin_bottom","set_margin_start","set_margin_end"): getattr(a, m)(14)
        info = Gtk.Label(label="Fetch individual wallpapers in parallel  →  %s" % DEST); info.set_xalign(0); info.get_style_context().add_class("sub")
        a.pack_start(info, False, False, 0)
        row = Gtk.Box(spacing=10)
        lbl = Gtk.Label(label="How many:"); lbl.get_style_context().add_class("sub"); row.pack_start(lbl, False, False, 0)
        spin = Gtk.SpinButton.new_with_range(1, 200, 5); spin.set_value(20); row.pack_start(spin, False, False, 0)
        src = Gtk.ComboBoxText()
        for s in ("Curated · GitHub", "Unsplash", "Both"): src.append_text(s)
        src.set_active(0); row.pack_start(src, False, False, 0)
        start = Gtk.Button(label="Download"); start.get_style_context().add_class("tool"); row.pack_end(start, False, False, 0)
        a.pack_start(row, False, False, 0)
        pb = Gtk.ProgressBar(); pb.set_show_text(True); a.pack_start(pb, False, False, 0)
        tv = Gtk.TextView(); tv.set_editable(False); tv.set_monospace(True); tv.get_style_context().add_class("cap")
        sc = Gtk.ScrolledWindow(); sc.set_policy(Gtk.PolicyType.NEVER, Gtk.PolicyType.AUTOMATIC); sc.add(tv); a.pack_start(sc, True, True, 0)
        buf = tv.get_buffer(); stop = {"v": False}
        d.connect("response", lambda *_a: (stop.__setitem__("v", True), d.destroy()))
        def log(t): GLib.idle_add(lambda: (buf.insert(buf.get_end_iter(), t), tv.scroll_to_iter(buf.get_end_iter(), 0, False, 0, 0)) and False)
        def setp(f, txt): GLib.idle_add(lambda: (pb.set_fraction(f), pb.set_text(txt)) and False)
        def done(): GLib.idle_add(lambda: (start.set_sensitive(True), start.set_label("Download")) and False)
        def run(limit, mode):
            os.makedirs(DEST, exist_ok=True)
            have = set(os.listdir(DEST))
            setp(0.0, "indexing…"); log("indexing sources…\n")
            cands = []
            if mode in (0, 2):                       # curated GitHub (tree API → raw URLs)
                srcs = list(SOURCES); random.shuffle(srcs)
                for owner, repo, branch, sub in srcs:
                    if stop["v"] or len(cands) >= limit * 4: break
                    br = branch or _gh_branch(owner, repo)
                    if br: cands += [c for c in _gh_images(owner, repo, br, sub) if c[1] not in have]
            if mode in (1, 2):                        # Unsplash API
                cands += [c for c in _unsplash_images(limit) if c[0] and c[1] not in have]
            random.shuffle(cands)
            if not cands:
                log("no images found (offline, or API rate limit — try again shortly).\n"); setp(0.0, "nothing to fetch"); done(); return
            log("downloading up to %d (from %d found), 8 at a time…\n" % (limit, len(cands)))
            added = [0]; lock = threading.Lock()
            def fetch(c):
                if stop["v"] or added[0] >= limit: return
                url, fn = c
                with lock:
                    if fn in have: return
                    have.add(fn)
                try:
                    data = _http(url, timeout=30)
                    if not data or len(data) < 2048: raise ValueError("too small")
                    with lock:
                        if added[0] >= limit: return
                    part = os.path.join(DEST, fn + ".part")
                    with open(part, "wb") as f: f.write(data)
                    os.replace(part, os.path.join(DEST, fn))
                    with lock:
                        added[0] += 1; n = added[0]
                    setp(min(n / limit, 1.0), "%d / %d wallpapers" % (n, limit)); log("  + %s\n" % fn)
                except Exception:
                    with lock: have.discard(fn)
            with _cf.ThreadPoolExecutor(max_workers=8) as ex:
                futs = [ex.submit(fetch, c) for c in cands]
                for _f in _cf.as_completed(futs):
                    if stop["v"] or added[0] >= limit: break
            setp(1.0, "done"); log("\nFinished — %d wallpapers added to %s\n" % (added[0], DEST))
            GLib.idle_add(self.load); done()
        def go(*_):
            start.set_sensitive(False); start.set_label("Downloading…"); stop["v"] = False
            threading.Thread(target=run, args=(int(spin.get_value()), src.get_active()), daemon=True).start()
        start.connect("clicked", go)
        d.show_all()   # non-modal; pick source + count, click Download. Per-image parallel fetch, accurate progress.

    def load(self):
        for c in self.flow.get_children(): c.destroy()
        self.papers = list_wallpapers()
        self.count.set_text("%d wallpapers" % len(self.papers))
        threading.Thread(target=self._load_thumbs, args=(list(self.papers),), daemon=True).start()

    def _load_thumbs(self, papers):
        for path in papers:
            try:
                pb = GdkPixbuf.Pixbuf.new_from_file_at_scale(path, THUMB_W, THUMB_H, False)
            except Exception:
                continue
            GLib.idle_add(self._add_thumb, path, pb)

    def _add_thumb(self, path, pb):
        img = Gtk.Image.new_from_pixbuf(pb); img.get_style_context().add_class("thumb")
        ev = Gtk.Button(); ev.set_relief(Gtk.ReliefStyle.NONE); ev.add(img)
        ev.set_tooltip_text(os.path.basename(path))
        ev.connect("clicked", lambda *_p, pp=path: set_wallpaper(pp))
        self.flow.add(ev); ev.show_all()
        return False

