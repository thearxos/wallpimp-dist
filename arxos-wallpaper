def sh(c):
    try: return subprocess.check_output(c, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except Exception: return ""

def list_wallpapers():
    seen, out = set(), []
    for d in DIRS:
        if not os.path.isdir(d): continue
        try: names = sorted(os.listdir(d))
        except Exception: continue
        for f in names:
            if f.lower().endswith(EXTS) and f not in seen:
                seen.add(f); out.append(os.path.join(d, f))
    return out

def workspaces():
    return [l[:-len("/last-image")] for l in sh("xfconf-query -c xfce4-desktop -l").splitlines() if l.endswith("/last-image")]

def set_wallpaper(path):
    ws = workspaces() or ["/backdrop/screen0/monitor0/workspace0"]
    for w in ws:
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/last-image","-s",path,"--create","-t","string"])
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/image-style","-t","int","-s","5","--create"])
    subprocess.Popen(["xfdesktop","--reload"])

def set_cycle(on, shuffle, secs=300):
    for w in workspaces():
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/backdrop-cycle-enable","-t","bool","-s",("true" if on else "false"),"--create"])
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/backdrop-cycle-period","-t","int","-s","1","--create"])
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/backdrop-cycle-timer","-t","uint","-s",str(secs),"--create"])
        subprocess.call(["xfconf-query","-c","xfce4-desktop","-p",w+"/backdrop-cycle-random-order","-t","bool","-s",("true" if shuffle else "false"),"--create"])

