#!/usr/bin/env bash
# arxos-slideshow - cycle the ArxOS wallpapers, 10 minutes each. Scans the SAME dirs the
# Wallpaper Manager (arxos-wallpaper) browses + installs to, so downloads join automatically.
INTERVAL=600
DIRS=(/usr/share/backgrounds/arxos "$HOME/Pictures/Wallpapers" "$HOME/Wallpapers")
i=$RANDOM
while :; do
  # re-scan each cycle so wallpapers installed via the manager appear without a restart
  declare -A seen=(); W=()
  for d in "${DIRS[@]}"; do
    [ -d "$d" ] || continue
    while IFS= read -r f; do
      b=${f##*/}; [ -n "${seen[$b]:-}" ] && continue; seen[$b]=1; W+=("$f")
    done < <(find "$d" -maxdepth 1 -type f \( -iname '*.png' -o -iname '*.jpg' -o -iname '*.jpeg' \) 2>/dev/null | sort)
  done
  if [ "${#W[@]}" -gt 0 ]; then
    img="${W[$(( i % ${#W[@]} ))]}"
    while read -r p; do xfconf-query -c xfce4-desktop -p "$p" -s "$img" 2>/dev/null; done \
      < <(xfconf-query -c xfce4-desktop -l 2>/dev/null | grep -E "/last-image$")
    command -v xwallpaper >/dev/null && xwallpaper --zoom "$img" 2>/dev/null
    i=$((i+1))
  fi
  sleep "$INTERVAL"
done
